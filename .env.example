# Copy to .env and fill in. Never commit .env.
# ---------------------------------------------

# LLM provider — OpenAI for now; multi-provider later.
OPENAI_API_KEY=sk-...
APPLYOPS_DEFAULT_MODEL=gpt-4.1
APPLYOPS_CRITIC_MODEL=gpt-4.1-mini
APPLYOPS_FACTCHECK_MODEL=gpt-4.1

# Observability (optional — pipeline runs without these, just no traces)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Run config
APPLYOPS_RUN_DIR=runs
APPLYOPS_FACTS_PATH=inputs/facts.local.json
APPLYOPS_JD_URL=https://ats.rippling.com/en-CA/opendoor/
APPLYOPS_RESUME_PDF=inputs/private/resume.pdf
