# Personal application data — only redacted examples ever land in git
inputs/*.local.*
inputs/private/
inputs/jd.*.md
!inputs/jd.example.md
outputs/
evidence/private/
*.resume.pdf
*.cv.pdf

# Traces / runs — generated, large, can leak content
runs/
traces/
.langfuse/

# Tooling
.python-version.local
.DS_Store
.idea/
.vscode/
*.swp
